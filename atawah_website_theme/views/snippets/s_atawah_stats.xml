<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_atawah_stats" name="Atawah Stats">
        <section class="s_atawah_stats" data-snippet="s_atawah_stats" data-name="Atawah Stats">
            <div class="container">
                <div class="atawah_stats_row">
                    <div class="atawah_stat_item">
                        <span class="atawah_stat_number" data-count="10" data-suffix="+">0</span>
                        <span class="atawah_stat_label">Years of practice</span>
                    </div>
                    <div class="atawah_stat_item">
                        <span class="atawah_stat_number" data-count="200" data-suffix="+">0</span>
                        <span class="atawah_stat_label">Clients served</span>
                    </div>
                    <div class="atawah_stat_item">
                        <span class="atawah_stat_number" data-count="95" data-suffix="%">0</span>
                        <span class="atawah_stat_label">Client retention</span>
                    </div>
                    <div class="atawah_stat_item">
                        <span class="atawah_stat_number" data-count="6" data-suffix="">0</span>
                        <span class="atawah_stat_label">Core service lines</span>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>

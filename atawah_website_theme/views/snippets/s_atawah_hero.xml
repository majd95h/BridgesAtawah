<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_atawah_hero" name="Atawah Hero">
        <section class="s_atawah_hero" data-snippet="s_atawah_hero" data-name="Atawah Hero">
            <div class="container">
                <div class="atawah_hero_stage">

                    <!-- Floating Cards - Scattered around central content -->
                    <div class="atawah_float_card atawah_float_note" aria-hidden="true">
                        <span class="atawah_float_note_label">Audit Note</span>
                        <p>"Independent assurance that strengthens stakeholder trust."</p>
                    </div>

                    <div class="atawah_float_card atawah_float_reminders" aria-hidden="true">
                        <span class="atawah_float_kicker">Reminders</span>
                        <span class="atawah_float_sub">Today</span>
                        <strong>Tax filing — DMCC client</strong>
                        <span class="atawah_float_sub">10:00 – 11:30</span>
                    </div>

                    <div class="atawah_float_card atawah_float_progress" aria-hidden="true">
                        <div class="atawah_float_progress_head">
                            <span>Q3 Closing</span>
                            <span class="atawah_pill_status">On track</span>
                        </div>
                        <div class="atawah_progress_row">
                            <span>VAT Filing</span>
                            <span>92%</span>
                        </div>
                        <div class="atawah_progress_bar">
                            <span style="width: 92%;"/>
                        </div>
                        <div class="atawah_progress_row">
                            <span>Reconciliation</span>
                            <span>68%</span>
                        </div>
                        <div class="atawah_progress_bar atawah_progress_green">
                            <span style="width: 68%;"/>
                        </div>
                    </div>

                    <div class="atawah_float_card atawah_float_tags" aria-hidden="true">
                        <span class="atawah_float_kicker">Odoo Integrations</span>
                        <div class="atawah_mockup_tags">
                            <span>Accounting</span>
                            <span>Inventory</span>
                            <span>CRM</span>
                            <span>HR</span>
                        </div>
                    </div>

                    <!-- Central Content -->
                    <div class="atawah_hero_content">
                        <div class="atawah_hero_logo">
                            <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="24" r="3.2" fill="#16294f"/>
                                <path d="M8 27 L17 15 L23 21 L32 8" fill="none" stroke="#3b78e0" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="32" cy="8" r="3.2" fill="#d98f2b"/>
                                <path d="M17 15 L23 21" stroke="#2f9e68" stroke-width="3" stroke-linecap="round"/>
                            </svg>
                        </div>

                        <div class="atawah_hero_badge">
                            <svg class="atawah_sparkle" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                <path d="M10 1l1.8 5.2L17 8l-5.2 1.8L10 15l-1.8-5.2L3 8l5.2-1.8L10 1z" fill="#d98f2b"/>
                            </svg>
                            Financial Consultancy &amp; Auditing · UAE
                        </div>

                        <h1 class="atawah_hero_title">Audit, advise, and grow with one trusted partner</h1>

                        <p class="atawah_hero_text">
                            ATAWAH gives ambitious businesses the audit, tax and ERP backbone they need — from clean books to board-ready strategy.
                        </p>

                        <div class="atawah_hero_actions">
                            <a href="#contact" class="btn atawah_btn_primary">
                                Book a consultation <span class="atawah_arrow">→</span>
                            </a>
                            <a href="#services" class="btn atawah_btn_ghost">Explore services</a>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </template>
</odoo>
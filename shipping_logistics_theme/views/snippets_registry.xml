<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="snippets_shipping" inherit_id="website.snippets" name="Shipping Snippets">
        <xpath expr="//snippets[@id='snippet_structure']/*[1]" position="before">
            <t t-snippet="shipping_logistics_theme.s_shipping_hero" string="Shipping Hero" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_hero.svg">
                <keywords>Hero, Header, Shipping</keywords>
            </t>

            <t t-snippet="shipping_logistics_theme.s_shipping_services" string="Shipping Services" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_services.svg">
                <keywords>Services, Canvas, Draggable</keywords>
            </t>
            <t t-snippet="shipping_logistics_theme.s_shipping_services_detail" string="Shipping Services Detail" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_services_detail.svg">
                <keywords>Services, Details, Industrial, Construction, Wholesale</keywords>
            </t>
            <t t-snippet="shipping_logistics_theme.s_shipping_testimonials_coverflow" string="Testimonials Coverflow" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_services.svg">
                <keywords>Coverflow, 3D</keywords>
            </t>

            <t t-snippet="shipping_logistics_theme.s_shipping_why" string="Shipping Why" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_why.svg">
                <keywords>Why, Benefits, Features</keywords>
            </t>

            <t t-snippet="shipping_logistics_theme.s_shipping_process" string="Shipping Process" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_process.svg">
                <keywords>Process, Steps, Timeline</keywords>
            </t>
               <t t-snippet="shipping_logistics_theme.s_shipping_process_quality" string="Shipping Process and Quality" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_process_quality.svg">
                <keywords>Process, Quality, QA, Assurance, Inspection</keywords>
            </t>

            <t t-snippet="shipping_logistics_theme.s_shipping_network" string="Shipping Network Map" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_network.svg">
                <keywords>Network, Map, Routes, Global</keywords>
            </t>

            <t t-snippet="shipping_logistics_theme.s_shipping_blog" string="Shipping Blog" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_blog.svg">
                <keywords>Blog, Articles, Knowledge</keywords>
            </t>

            <t t-snippet="shipping_logistics_theme.s_shipping_footer_contact" string="Shipping CTA" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_cta.svg">
                <keywords>CTA, Call to Action, Contact</keywords>
            </t>
             <t t-snippet="shipping_logistics_theme.s_shipping_import_form" string="Shipping Import Form" group="structure"
               t-thumbnail="/shipping_logistics_theme/static/src/img/thumbs/s_shipping_import_form.svg">
                <keywords>Form, Request, Import, Order, Contact</keywords>
            </t> 
        </xpath>
    </template>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_shipping_hero" name="Shipping Hero">
        <section class="s_shipping_hero" data-snippet="s_shipping_hero" data-name="Shipping Hero">
            <div class="container">
                <div class="shipping_hero_stage">
                <!-- Company Logo -->
                    <div class="shipping_hero_logo">
    <t t-if="website.company_id.logo">
        <img t-att-src="image_data_uri(website.company_id.logo)" t-att-alt="website.company_id.name" />
    </t>
    <t t-else="">
        <div style="font-size: 24px; color: #D4AF37; font-weight: bold;">
            <t t-out="website.company_id.name"/>
        </div>
    </t>
</div>
                    <!-- بطاقة 1: Your Partner (أصفر) -->
                    <div class="shipping_float_card shipping_float_note" aria-hidden="true">
                        <span class="shipping_float_note_label">Your Partner</span>
                        <p>"Your trusted business &amp; logistics partner for safe import from China."</p>
                    </div>

                    <!-- بطاقة 2: Our Mission -->
                    <div class="shipping_float_card shipping_float_mission" aria-hidden="true">
                        <span class="shipping_float_kicker">Our Mission</span>
                        <p>Empowering clients to achieve business goals through flexible and reliable import solutions.</p>
                    </div>

                    <!-- بطاقة 3: Why Choose Us -->
                    <div class="shipping_float_card shipping_float_why" aria-hidden="true">
                        <span class="shipping_float_kicker">Why Choose Us</span>
                        <ul class="shipping_float_list">
                            <li>Local Network in China</li>
                            <li>Quality Inspection</li>
                            <li>Integrated Logistics</li>
                        </ul>
                    </div>

                    <!-- بطاقة 4: Key Stats -->
                    <div class="shipping_float_card shipping_float_stats" aria-hidden="true">
                        <span class="shipping_float_kicker">Our Commitment</span>
                        <div class="shipping_float_stat">
                            <strong>100%</strong>
                            <span>Transparency</span>
                        </div>
                        <div class="shipping_float_stat">
                            <strong>24/7</strong>
                            <span>Support Ready</span>
                        </div>
                    </div>

                    <!-- المحتوى المركزي -->
                    <div class="shipping_hero_content">
                        <h1 class="shipping_hero_title">Your Trusted Business &amp; Logistics Partner for Safe Import from China</h1>

                        <p class="shipping_hero_text">
                            We provide integrated and customized solutions for individuals, companies, and factories; starting from searching for the best suppliers and verifying product quality, all the way to shipping and customs clearance.
                        </p>

                        <div class="shipping_hero_actions">
                            <a href="#contact" class="btn shipping_btn_primary">
                                Start Your Import Request Now <span class="shipping_arrow">→</span>
                            </a>
                            <a href="#services" class="btn shipping_btn_primary">Browse Our Services</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>

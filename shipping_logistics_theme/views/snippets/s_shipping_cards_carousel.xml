<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_shipping_testimonials_coverflow" name="3D Testimonials Coverflow">
        <section class="s_shipping_testimonials_coverflow s_shipping_testimonials pt96 pb96" data-snippet="s_shipping_testimonials_coverflow" data-name="Client Satisfaction">
            <div class="container">
                <!-- Section Header -->
                <div class="shipping_section_head shipping_section_head_center">
                    <h2>Trusted by Our <em>Clients</em></h2>
                    <p>Hear what our partners have to say about their safe import experiences from China.</p>
                </div>

                <!-- 3D Coverflow Stage -->
                <div class="shipping_coverflow_wrapper">
                    <div class="shipping_coverflow_deck" id="testimonial_deck">
                        
                        <!-- Card 1 -->
                        <div class="shipping_coverflow_card slide">
                            <div class="shipping_quote_mark">"</div>
                            <div class="shipping_stars">★★★★★</div>
                            <p class="shipping_testi_text">"Bridges Overseas transformed our import process. They handled the quality inspection and shipping of our factory machinery with 100% transparency."</p>
                            <div class="shipping_testi_author">
                                <strong>Ahmed Al-Farsi</strong>
                                <span>CEO, Industrial Tech</span>
                            </div>
                        </div>

                        <!-- Card 2 -->
                        <div class="shipping_coverflow_card slide">
                            <div class="shipping_quote_mark">"</div>
                            <div class="shipping_stars">★★★★★</div>
                            <p class="shipping_testi_text">"As a startup, we needed a reliable partner in China. Their local network secured us the best suppliers. Exceptional 24/7 support."</p>
                            <div class="shipping_testi_author">
                                <strong>Sarah Chen</strong>
                                <span>Operations Manager</span>
                            </div>
                        </div>

                        <!-- Card 3 -->
                        <div class="shipping_coverflow_card slide">
                            <div class="shipping_quote_mark">"</div>
                            <div class="shipping_stars">★★★★★</div>
                            <p class="shipping_testi_text">"Fulfilling our LCL individual orders used to be a nightmare. Their consolidation services are flexible, fast, and highly cost-effective."</p>
                            <div class="shipping_testi_author">
                                <strong>Omar Tariq</strong>
                                <span>E-commerce Founder</span>
                            </div>
                        </div>

                        <!-- Card 4 -->
                        <div class="shipping_coverflow_card slide">
                            <div class="shipping_quote_mark">"</div>
                            <div class="shipping_stars">★★★★★</div>
                            <p class="shipping_testi_text">"The level of detail in their quality inspections is unmatched. We received exactly what we ordered, on time, with zero defects."</p>
                            <div class="shipping_testi_author">
                                <strong>Fatima Al-Sayed</strong>
                                <span>Procurement Director</span>
                            </div>
                        </div>

                        <!-- Card 5 -->
                        <div class="shipping_coverflow_card slide">
                            <div class="shipping_quote_mark">"</div>
                            <div class="shipping_stars">★★★★★</div>
                            <p class="shipping_testi_text">"From finding the suppliers to final customs clearance in our home country, everything was seamless. Truly a trusted partner."</p>
                            <div class="shipping_testi_author">
                                <strong>Michael Zhou</strong>
                                <span>Global Trade Corp</span>
                            </div>
                        </div>

                    </div>
                    
                    <!-- Carousel Controls -->
                    <div class="shipping_carousel_controls">
                        <button class="shipping_btn_ghost btn_prev" style="color:#000 !important;">←</button>
                        <button class="shipping_btn_ghost btn_next" style="color:#000 !important;">→</button>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="website.homepage" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <record id="page_home" model="website.page">
        <field name="name">Home</field>
        <field name="key">shipping_logistics_theme.page_home</field>
        <field name="url">/</field>
        <field name="type">qweb</field>
        <field name="is_published" eval="True"/>
        <field name="is_homepage" eval="True"/>
        <field name="website_id" ref="website.default_website"/>
        <field name="arch" type="xml">
            <t t-name="shipping_logistics_theme.page_home">
                <t t-call="website.layout">
                    <t t-set="additional_title">Shipping &amp; Logistics - Import from China</t>
                    <div id="wrap" class="oe_structure">
                        <t t-call="shipping_logistics_theme.s_shipping_hero"/>
                        <t t-call="shipping_logistics_theme.s_shipping_services"/>
                        <t t-call="shipping_logistics_theme.s_shipping_testimonials_coverflow"/>
                        <t t-call="shipping_logistics_theme.s_shipping_why"/>
                        <t t-call="shipping_logistics_theme.s_shipping_process"/>
                        <t t-call="shipping_logistics_theme.s_shipping_network"/>
                        <t t-call="shipping_logistics_theme.s_shipping_blog"/>
                        <t t-call="shipping_logistics_theme.s_shipping_footer_contact"/>
                        <t t-call="shipping_logistics_theme.s_shipping_about"/>
                        <t t-call="shipping_logistics_theme.s_shipping_services_detail"/>
                        <t t-call="shipping_logistics_theme.s_shipping_process_quality"/>
                        <t t-call="shipping_logistics_theme.s_shipping_import_form"/>
                        <t t-call="shipping_logistics_theme.s_shipping_blog_articles"/>
                    </div>
                </t>
            </t>
        </field>
    </record>
</odoo>